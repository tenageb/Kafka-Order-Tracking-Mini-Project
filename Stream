version: '3.8'

services:
  kafka:
    image: confluentinc/cp-kafka:7.7.8
    container_name: kafka
    ports:
      - "9092:9092"

    # Environmental variables
    environment:
      KAFKA_KRAFT_MODE: 'true'

      # set the cluster ID
      CLUSTER_ID: '1L6g7nGhu-eAKfl--X25wo' # This is random Id
      KAFKA_NODE_ID: 1  # specify number of nodes or kafka-broker.

      KAFKA_PROCESS_ROLES: 'broker,controller' # The above broker plays as a broker and a controller as well.
      KAFKA_CONTROLLER_QUORUM_VOTERS: '1@kafka:9093' # if you have more controllers, list them here like 2@kafka:9093:...
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: 1  # No BACKUP, JUST 1 COPY
      KAFKA_LISTENERS: 'PLAINTEXT://0.0.0.0:9092,CONTROLLER://0.0.0.0:9093' # NODE TO NODE COMMUNICATION
      KAFKA_ADVERTISED_LISTENERS: 'PLAINTEXT://localhost:9092'
      KAFKA_CONTROLLER_LISTENER_NAMES: 'CONTROLLER'
      KAFKA_LOG_DIRS: '/tmp/kraft-combined-logs'  

    volumes:
      - kafka_kraft:/var/lib/kafka/data

volumes:
  kafka_kraft: # in our computer
